{
  "name": "eigen-auction",
  "private": true,
  "scripts": {
    "approve": "pnpm -F @eigen-auction/backend approve",
    "post-batch": "pnpm -F @eigen-auction/backend post-batch",
    "drive-round": "pnpm -F @eigen-auction/backend drive-round",
    "results": "pnpm -F @eigen-auction/backend results",
    "frontend:build": "pnpm -F @eigen-auction/frontend build",
    "frontend:preview": "pnpm -F @eigen-auction/frontend preview",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "aspire:start": "pnpm --dir aspire-apphost run aspire:start",
    "aspire:build": "pnpm --dir aspire-apphost run aspire:build",
    "aspire:dev": "pnpm --dir aspire-apphost run aspire:dev"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
