# Values are loaded by BOTH dotenv (backend) and `include .env` (Makefile). Make does not strip
# inline `# comments` or surrounding quotes, so keep every value on its own line, bare, with no
# trailing comment. Put explanations on their own comment lines like these.

# Two deployment targets are supported; pick one and set RPC_URL + CHAIN_ID to match.
#
# A) Local mainnet fork (make anvil-fork + make deploy-fork) -> CHAIN_ID=1
# B) Sepolia testnet (make deploy-testnet) -> CHAIN_ID=11155111
#
# Contract addresses are NOT set here. The deploy script writes deployments/<CHAIN_ID>.json and the
# backend/frontend read that single artifact. Override the lookup dir only if needed:
# DEPLOYMENTS_DIR=deployments

# Fork source (used by `make anvil-fork` only)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<key>

# Sepolia RPC (used by `make deploy-testnet`; also set RPC_URL=this and CHAIN_ID=11155111 for B)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<key>

# Endpoints the running services talk to. For the fork this is the local anvil; for Sepolia set it to
# SEPOLIA_RPC_URL.
RPC_URL=http://127.0.0.1:8545
# Fork preserves the forked chain's id (mainnet fork => 1); Sepolia => 11155111.
CHAIN_ID=1
REDIS_URL=redis://127.0.0.1:6379

# DEPLOYER_PK deploys contracts + is the funded LP / intent user in the demo.
DEPLOYER_PK=0x...
# OPERATOR_PK is the AVS operator signing key (registered operator-set member).
OPERATOR_PK=0x...
# SETTLER_CALLER_PK calls Settler.settle; MUST equal the committed winner (set == OPERATOR_PK).
SETTLER_CALLER_PK=0x...

# Price feed
PRICE_SOURCE=fixed
# currency1 per currency0 in whole tokens, set off the pool's start price to create an arb gap.
# Fork (USDC currency0 / WETH currency1):   WETH per USDC, e.g. 0.0005 ~ 2000 USDC/WETH.
# Sepolia (mUSD/mETH 18dp): pool starts at 1:1, so a value like 1.03 opens a ~3% gap.
FIXED_PRICE=0.0005

# avs-rpc
INTENT_PORT=8088

# ── Go AVS services (operator + aggregator + register) ───────────────────────────────────
# Websocket RPC (anvil serves ws on the same port: `anvil ... --ws` or use ws://127.0.0.1:8545).
# The aggregator's operator-info subscriber and cmd/register need this.
WS_URL=ws://127.0.0.1:8545
# Where the Go operator pulls the sealed set (the relay / avs-rpc).
FEED_URL=http://127.0.0.1:8088
# Where the Go operator submits its BLS-signed response, and where the aggregator listens.
AGGREGATOR_URL=http://127.0.0.1:9090
LISTEN_ADDR=:9090
# The key the aggregator uses to submit commitWinner (any funded account; may equal DEPLOYER_PK).
AGGREGATOR_PK=0x...
# The operator's BN254 BLS private key (decimal or hex). Distinct from OPERATOR_PK (its ECDSA key).
BLS_PRIVATE_KEY=0x...
# EL-core addresses cmd/register needs but that aren't in the deployment artifact (from config/networks/1.json).
REWARDS_COORDINATOR=0x7750d328b314EfFa365A0402CcfD489B80B0adda
PERMISSION_CONTROLLER=0x25E5F8B1E7aDf44518d35D5B2271f114e081f0E5
# Optional: set to also deposit + allocate stake in cmd/register (raw token amount, allocation magnitude).
# STAKE_AMOUNT=1000000000000000000
# STAKE_MAGNITUDE=1000000000000000000

# Frontend (Vite build-time env vars — baked into the JS bundle at `docker compose build frontend`
# or `npm run frontend:build`). VITE_RPC_URL and VITE_CHAIN_ID must match the deployment target.
# These are NOT loaded by dotenv/Makefile — set them as shell env vars before building the image.
VITE_CHAIN_ID=11155111
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<key>
VITE_INTENT_URL=http://localhost:8088
